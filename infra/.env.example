# ============================================================
#  FutureKawa — Variables d'environnement
#  Copiez ce fichier en ".env" puis ajustez si besoin :
#     cp .env.example .env
# ============================================================

# --- Bases de données PostgreSQL (identifiants partagés) ---
DB_USER=futurekawa
DB_PASSWORD=futurekawa

# --- Sécurité du back-end central ---
# Secret de signature des jetons JWT.
# OBLIGATOIRE en production : remplacez par une longue chaîne
# aléatoire d'au moins 32 caractères.
JWT_SECRET=changez-moi-en-production-secret-de-32-caracteres-minimum
